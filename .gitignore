/target
/.env
/.env.*
.DS_Store
/backlog/.audit.log
/backlog/.index/
/workmesh/.audit.log
/workmesh/.index/
#
# WorkMesh runtime locks (cross-process locking artifacts)
# Keep lock files out of git status while preserving Cargo.lock tracking.
/workmesh/.locks/
/workmesh/**/.locks/
/.workmesh/.locks/
/.workmesh/**/.locks/
/backlog/.locks/
/backlog/**/.locks/

# Legacy lock-file layout (pre-.locks pathing)
/workmesh/**/*.lock
/.workmesh/**/*.lock
/backlog/**/*.lock
/.workmesh/.audit.log
/.workmesh/.index/
# Go
/bin/
/pkg/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Coverage artifacts
*.profraw
lcov.info
